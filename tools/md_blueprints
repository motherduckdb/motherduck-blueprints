#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

if command -v md-blueprints >/dev/null 2>&1; then
  exec md-blueprints "$@"
fi

if [ -x "${REPO_ROOT}/.venv/bin/md-blueprints" ]; then
  exec "${REPO_ROOT}/.venv/bin/md-blueprints" "$@"
fi

export PYTHONPATH="${REPO_ROOT}/src${PYTHONPATH:+:${PYTHONPATH}}"
exec python3 -m md_blueprints "$@"
